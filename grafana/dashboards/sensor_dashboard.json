{
  "id": null,
  "uid": "sensor-observability",
  "title": "Edge Sensor Observability",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["sensor", "edge"],
  "time": {
    "from": "now-2h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Sensor Service CPU Usage (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sensor_service_cpu_percent",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sensor Service Memory Usage (MB)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sensor_service_memory_bytes / 1024 / 1024",
          "legendFormat": "RSS MB",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sensor Event Rate (events/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(sensor_events_total[1m])",
          "legendFormat": "events/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sensor Processing Latency (p50/p90/p99)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(sensor_processing_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.9, sum(rate(sensor_processing_seconds_bucket[5m])) by (le))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(sensor_processing_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sensor Queue Depth",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sensor_queue_depth",
          "legendFormat": "queue depth",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sensor Failures (5m rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(sensor_failures_total[5m])",
          "legendFormat": "failures/s",
          "refId": "A"
        }
      ]
    }
  ]
}

